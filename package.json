{
  "name": "farmacia-ds",
  "version": "2026.05.06",
  "description": "Farmácia UFMG Design System Assets",
  "main": "dist/latest/farmacia-ds.min.js",
  "scripts": {
    "build:css": "postcss src/farmacia-ds.css -o dist/v2026.05.06/farmacia-ds.min.css --map",
    "build:js": "esbuild src/farmacia-ds.js --bundle --minify --sourcemap --outfile=dist/v2026.05.06/farmacia-ds.min.js",
    "build:fonts": "mkdir -p dist/latest/fonts dist/v2026.05.06/fonts && cp fonts/*.woff2 dist/v2026.05.06/fonts/ || true",
    "build:symlinks": "rm -rf dist/latest/* && cp -r dist/v2026.05.06/* dist/latest/",
    "build": "mkdir -p dist/v2026.05.06 dist/latest && npm run build:css && npm run build:js && npm run build:fonts && npm run build:symlinks"
  },
  "devDependencies": {
    "autoprefixer": "^10.5.0",
    "cssnano": "^6.0.3",
    "esbuild": "^0.28.0",
    "postcss": "^8.4.35",
    "postcss-cli": "^11.0.1",
    "terser": "^5.29.1"
  },
  "dependencies": {
    "lucide": "^1.11.0",
    "postcss-import": "^16.1.1"
  }
}
